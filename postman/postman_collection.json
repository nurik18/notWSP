{
  "info": {
    "name": "Student Portal API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ivan\",\n  \"password\": \"secret123\",\n  \"email\": \"ivan@example.com\",\n  \"first_name\": \"Иван\",\n  \"last_name\": \"Петров\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ivan\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Token {{token}}"}
            ],
            "url": "{{base_url}}/auth/logout/"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "List Courses",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Token {{token}}"}],
            "url": "{{base_url}}/courses/"
          }
        }
      ]
    },
    {
      "name": "Schedule",
      "item": [
        {
          "name": "List Schedule",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Token {{token}}"}],
            "url": "{{base_url}}/schedule/"
          }
        },
        {
          "name": "List Schedule by Course",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Token {{token}}"}],
            "url": {
              "raw": "{{base_url}}/schedule/?course_id=1",
              "query": [{"key": "course_id", "value": "1"}]
            }
          }
        }
      ]
    },
    {
      "name": "Grades",
      "item": [
        {
          "name": "List My Grades",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Token {{token}}"}],
            "url": "{{base_url}}/grades/"
          }
        },
        {
          "name": "Add Grade",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Token {{token}}"}
            ],
            "url": "{{base_url}}/grades/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": 1,\n  \"score\": \"85.00\",\n  \"comment\": \"Хорошая работа\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Assignments",
      "item": [
        {
          "name": "List My Assignments",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Token {{token}}"}],
            "url": "{{base_url}}/assignments/"
          }
        },
        {
          "name": "Create Assignment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Token {{token}}"}
            ],
            "url": "{{base_url}}/assignments/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course\": 1,\n  \"title\": \"Домашнее задание №1\",\n  \"description\": \"Решить задачи 1-10\",\n  \"due_date\": \"2024-10-15\",\n  \"status\": \"pending\"\n}"
            }
          }
        },
        {
          "name": "Get Assignment",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Token {{token}}"}],
            "url": "{{base_url}}/assignments/1/"
          }
        },
        {
          "name": "Update Assignment",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Token {{token}}"}
            ],
            "url": "{{base_url}}/assignments/1/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course\": 1,\n  \"title\": \"Обновлённое задание\",\n  \"description\": \"Решить задачи 1-15\",\n  \"due_date\": \"2024-10-20\",\n  \"status\": \"in_progress\"\n}"
            }
          }
        },
        {
          "name": "Delete Assignment",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Token {{token}}"}],
            "url": "{{base_url}}/assignments/1/"
          }
        }
      ]
    }
  ]
}